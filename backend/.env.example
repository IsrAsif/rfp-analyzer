# Copy this file to .env and fill in your key. Never commit the real .env file.

# Which provider /api/analyze should call: "gemini" (has a free tier) or "anthropic".
AI_PROVIDER=gemini

# ── Gemini (Google AI Studio) ───────────────────────────────────────────
# Free tier, no credit card required: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── Anthropic (Claude) ───────────────────────────────────────────────────
# Requires a funded Anthropic Console account (console.anthropic.com).
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-5

PORT=3001

# Comma-separated list of origins allowed to call this backend.
# Use * only for local development.
CORS_ORIGIN=*
